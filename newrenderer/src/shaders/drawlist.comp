//TODO: pull all the debug ifdefs and visualizations into extra pass, exclude from drawlist generation
//since it's all post-generation anyways. to debug e.g. the parallel job binning algorithm, it would make sense, but not for this

void main() {
    uint global_thread_id = gl_GlobalInvocationID.x;

#ifdef DEBUG_GRID_OVERLAY
    DEBUG_grid_overlay(global_thread_id);
#endif

    if (global_thread_id >= uChunkCount) return;

    ChunkMeta cm = chunkMetas[global_thread_id];
    uint chunkScale = (cm.chunkID >> 24) & 0x7F;
    if((chunkScale & uShowMask) == 0) return;

    if (cm.batchCount == 0) return;
    //if (cm.batchCount > 100) return; //REVEAL(load balancing, upper limit of rows per chunk)

    vec3 chunkGlobalPos = vec3(unpack_uvec4(cm.chunkID).yzw) - vec3(127); //TODO 0.5 chunk width shift?
    //if(length(chunkGlobalPos * chunkScale) <= 0.75) return;
    
#ifdef DEBUG_CULLING_MINIMAP
    ivec2 dbg_px_pos = ivec2(chunkGlobalPos.xz * 4.0 * chunkScale) + ivec2(600, 600);
    DEBUG_fillPixelThick(2 * chunkScale, dbg_px_pos + 1, vec4(vec3(0.4), 1.0));
#endif

    if(!chunkInFrustum(chunkGlobalPos, chunkScale)) return;

#ifdef DEBUG_CULLING_MINIMAP
    DEBUG_fillPixelThick(2 * chunkScale, dbg_px_pos, vec4(1.0, -chunkGlobalPos.y /8.0, chunkGlobalPos.y / 4.0, 1.0));
#endif

    ivec2 tile = pickAssignmentTile(chunkGlobalPos, chunkScale);

    //REVEAL(limit of high-LOD loading distance/screensize of chunks)
    //set to high precision if chunk large enough in on-screen pixels
    float onScreenRadius = estimateOnscreenSize(chunkGlobalPos, chunkScale);
    uint flagged_as_requiring_high_lod = (onScreenRadius > HIGH_LOD_PX_THRESHOLD) ? 1 : 0;
    cm.chunkID |= flagged_as_requiring_high_lod << 31; //set "high-precision" bit

    uint tileID_flat = uint(tile.y * TILE_GRID_DIMENSIONS.x + tile.x);
    enqueueChunk(tileID_flat, cm);

    ivec2 chunkOnScreenPos = toScreen((chunkGlobalPos + 0.5) * uChunkSize * chunkScale);

#ifdef DEBUG_VISUALIZE_LOD_RADIUS
    bool debugShowRadius = pseudorandomChunkSelect(cm.chunkID) && chunkScale > 10;

    if(debugShowRadius) { //REVEAL(screen area radius limit deduction from circular radius)
        vec4 color = vec4(1, 0, 1, 1);
        if(onScreenRadius > HIGH_LOD_PX_THRESHOLD) {
            color = vec4(1, 0, 0, 1);
            onScreenRadius = HIGH_LOD_PX_THRESHOLD;
        }
        DEBUG_drawVoxelOutline(chunkGlobalPos, 1.0, vec4(0.8,0.5,0,1), chunkScale);
        DEBUG_drawCircle(chunkOnScreenPos, onScreenRadius, color);
    }
#endif

#ifdef DEBUG_VISUALIZE_BINNING
    if(tileID_flat % 37 == 0) {
        ivec2 tileBasePx = tile * TILE_SIZE;
        ivec2 tileMidPx = tileBasePx + TILE_SIZE / 2;

        if(chunkOnScreenPos.x >= 0 && tileMidPx.x < uResolution.x - TILE_SIZE && tileMidPx.y < uResolution.y - TILE_SIZE) {
            
            DEBUG_drawVoxelOutline(chunkGlobalPos, 1.0, vec4(0.8,0.5,0,1), chunkScale);
            DEBUG_drawCross(chunkOnScreenPos, 8, vec4(1,0,0,1));
            DEBUG_drawLine(chunkOnScreenPos, tileMidPx, vec4(1,0,0,1));

            const vec4 col2 = vec4(0.1,1,0,1);

            DEBUG_drawCross(tileMidPx, 16, col2);
            DEBUG_draw2dBox(tileBasePx, TILE_SIZE, false, col2);
        }
    }
#endif
}