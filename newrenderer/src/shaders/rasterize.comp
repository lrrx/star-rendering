uniform float uParsecToMeter = 3.08567758e16;
uniform bool uLumiThresholdEnabled;
uniform float uLuminanceMultiplicator = 1e6;

struct ChunkMeta {
    uint startBatch;
    uint batchCount;
    uint lastBatchRowCount;
    uint chunkID;
};

struct Job {
    uint count;
    uint id_per_tile;
    uint tileID_flat;
    uint pad0;
    ChunkMeta list[MAX_JOB_CHUNKS];
};

layout(std430, binding = 2) readonly buffer GpuJobsSSBO {
    Job joblist[];
};

layout(std430, binding = 0) readonly buffer GpuBatchesFlatSSBO {
    uint batchesFlat[];
};

layout(std430, binding = 6) readonly buffer GpuHighPrecisionBatchesFlatSSBO {
    uint highPrecisionBatchesFlat[];
};

layout(std430, binding = 4) buffer GpuProfilingSSBO {
    uint profiling_StarsDrawn;
    uint profiling_ChunksDrawn;
    uint profiling_TilesDrawn;
    uint profiling_StarsTotal;
    uint profiling_JobCount;
    uint profiling_WritesSharedClear; //writes for clearing tile
    uint profiling_WritesShared;   // taps that hit the LDS tile
    uint profiling_writesGlobalDirect;   // taps that fell through to addToFramebuffer
    uint profiling_writesGlobalFlush; //framebuffer writes when flushing LDS tile
};

