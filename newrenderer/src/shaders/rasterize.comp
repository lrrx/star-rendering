uvec3 unpackVec10(uint v) {
    return uvec3(
        (v >> 20u) & 0x3FFu,
        (v >> 10u) & 0x3FFu,
        (v >>  0u) & 0x3FFu
    );
}

vec3 decodeFull(uint lowPrecision, uint midPrecision, uint highPrecision) {
    uvec3 r = unpackVec10(lowPrecision);
    r = (r << 10u) + unpackVec10(midPrecision); //REVEAL(LOD,precision) *50 factor to exaggerate
    r = (r <<  4u) + unpackVec10(highPrecision);
    return vec3(r) / float(1u << 24u);  //16777216.0 aka 2^24 (float32 mantissa bits)
}

vec3 toScreen(vec3 pos) {
    vec3 ret = vec3(-1);

    // Clip Space
    vec4 clip = vec4(0.0);
    clip = uViewProj * uMatModel * vec4(pos * uParsecToMeter, 1.0); //TODO: premultiply uMatModel * uViewProj? need to be careful with relation to uInvP tho

    if (clip.w <= 0.0) return ret;

    // NDC
    vec3 ndc = clip.xyz / clip.w;


    
    if (abs(ndc.x) > 1.0 || abs(ndc.y) > 1.0 || abs(ndc.z) > 1.0)
        return ret;

    // Pixel-Koordinaten
    vec3 pixel;
    pixel.x = float((ndc.x * 0.5 + 0.5) * float(uResolution.x));
    pixel.y = float((ndc.y * 0.5 + 0.5) * float(uResolution.y));
    pixel.z = ndc.z;

    if (pixel.x < 0 || pixel.x >= uResolution.x ||
        pixel.y < 0 || pixel.y >= uResolution.y)
        return ret;

    return pixel;
}

void writePixel(ivec2 tile_local_pos, ivec2 pixel, float temp, float lumi) {
    int tempLumiInt = int(temp * lumi * 10000000.0 * uLuminanceMultiplicator);
    int lumiInt = int(lumi * 10000000.0 * uLuminanceMultiplicator);

#ifdef RASTERIZE_USE_TILE_ACCUMULATION
    if (
        tile_local_pos.x >= 0  && tile_local_pos.y >= 0  &&
        tile_local_pos.x < TILE_SIZE && tile_local_pos.y < TILE_SIZE
    ) {
        uvec2 p = uvec2(tile_local_pos);
#ifdef WRITE_PROFILING_COUNTERS
        writesShared[gl_LocalInvocationID.x] += 1u;
#endif
        atomicAdd(tileTemp[p.y][p.x], tempLumiInt);
        atomicAdd(tileLumi[p.y][p.x], lumiInt);
        return;
    }
#endif
#ifdef WRITE_PROFILING_COUNTERS
    writesGlobalDirect[gl_LocalInvocationID.x] += 1u;
#endif
    addToFramebuffer(pixel, tempLumiInt, lumiInt);
}

