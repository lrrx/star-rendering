void addToFramebuffer(ivec2 pixel, int tempLumi, int lumi) {
    uint lane = gl_WorkGroupID.x % 2u;
    uint fbOffsetFromLane = uResolution.y * lane;

    uint index_base = (uResolution.x * pixel.y + pixel.x) * 2;

    atomicAdd(accum[index_base + 0], tempLumi);
    atomicAdd(accum[index_base + 1], lumi);
}

//#define RASTERIZE_USE_TILE_ACCUMULATION //REVEAL (tilebased rendering, accumulation, io)
#ifdef RASTERIZE_USE_TILE_ACCUMULATION
// [y][x] layout: word index = y*TILE_SIZE + x  ->  bank = x % 32.
// x varies across lanes (and along an edge-on disk), so accesses spread across banks.
shared int tileTemp[TILE_SIZE][TILE_SIZE]; // luminance-weighted temperature accum
shared int tileLumi[TILE_SIZE][TILE_SIZE]; // luminance accum

float rand(float n){
    return abs(fract(sin(n) * 43758.5453123));
}

void clearTile() {
    uint lid = gl_LocalInvocationID.x;
    // 4096 cells / 512 threads = 16 cells per thread
    for (uint i = lid; i < TILE_SIZE * TILE_SIZE; i += THREAD_COUNT) {
        uint x = i % TILE_SIZE;          // consecutive lanes -> consecutive x -> distinct banks
        uint y = i / TILE_SIZE;          // can be bit ops if TILE_SIZE is power of 2
#ifdef WRITE_PROFILING_COUNTERS
        writesSharedClear[gl_LocalInvocationID.x] += 1u;
#endif
        tileTemp[y][x] = 0;
        tileLumi[y][x] = 0;
    }
}

void flushTile(uvec2 tileBasePx) {
    uint lid = gl_LocalInvocationID.x;
    for (uint i = lid; i < TILE_SIZE * TILE_SIZE; i += THREAD_COUNT) {
        uint x = i % TILE_SIZE;
        uint y = i / TILE_SIZE;
        ivec2 pixel = ivec2(x, y) + ivec2(tileBasePx);
        if (pixel.x < uResolution.x && pixel.y < uResolution.y) {
            int lumi = tileLumi[y][x];
            if (lumi == 0) continue;
            int tempAccumulated = tileTemp[y][x];
#ifdef WRITE_PROFILING_COUNTERS
            writesGlobalFlush[gl_LocalInvocationID.x] += 1u;
#endif
            addToFramebuffer(pixel, tempAccumulated, lumi);
        }
    }
}

#endif

