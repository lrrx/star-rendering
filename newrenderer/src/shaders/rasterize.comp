vec3 decode_morton(uint morton) {
    uint x = morton;
    uint y = morton >> 1;
    uint z = morton >> 2;
    x &=                   0x09249249u;
    x = (x ^ (x >>  2)) &  0x030c30c3u;
    x = (x ^ (x >>  4)) &  0x0f00f00fu;
    x = (x ^ (x >>  8)) &  0xff0000ffu;
    x = (x ^ (x >> 16)) &  0x0000ffffu;
    y &=                   0x09249249u;
    y = (y ^ (y >>  2)) &  0x030c30c3u;
    y = (y ^ (y >>  4)) &  0x0f00f00fu;
    y = (y ^ (y >>  8)) &  0xff0000ffu;
    y = (y ^ (y >> 16)) &  0x0000ffffu;
    z &=                   0x09249249u;
    z = (z ^ (z >>  2)) &  0x030c30c3u;
    z = (z ^ (z >>  4)) &  0x0f00f00fu;
    z = (z ^ (z >>  8)) &  0xff0000ffu;
    z = (z ^ (z >> 16)) &  0x0000ffffu;
    return vec3(x, y, z) / float(0x3ff);
}

