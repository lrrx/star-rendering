mat3 rotY(float a) {
    float c = cos(a), s = sin(a);
    return mat3(
        vec3( c, 0,-s),
        vec3( 0, 1, 0),
        vec3( s, 0, c)
    );
}


// Decode magnitude from upper 16 bits
float decodeMag(uint magTemp)
{
    uint magEnc = magTemp >> 16;          // upper 16 bits
    float f = float(magEnc) / 65535.0;    // back to [0,1]
    return f * 30.0 - 10.0;               // undo (mag + 10) / 30
}

// Decode temperature from lower 16 bits
float decodeTemp(uint magTemp)
{
    uint tempEnc = magTemp & 0xFFFFu;     // lower 16 bits
    return float(tempEnc);                // direct mapping
}

uint drawStar(uint posEncoded, uint posEncodedHighPrecision, vec3 chunkGlobalPos, uvec2 tileBasePx, float absMag, float temp, float chunkScale) {
    vec3 local_pos = vec3(decodeFull(posEncoded, posEncodedHighPrecision, 0).xyz); //REVEAL(morton vs. 10-10-10 packed)
    vec3 global_pos = (local_pos + chunkGlobalPos) * uChunkSize * chunkScale;

    //if(length(global_pos) > 250.0) return 0;
    //global_pos.y /= 5.0;
    //global_pos += uTime * local_pos * 100.0;
    //global_pos = rotY((uTime * 5.0 + 0.0) / pow(length(global_pos), 1.5) * 1000.0) * global_pos;
    vec3 pixel_and_depth = toScreen(global_pos);

    ivec2 screen_pos = ivec2(pixel_and_depth.xy);
    if(
        screen_pos.x < 0 || screen_pos.y < 0 ||
        screen_pos.x > uResolution.x - 1|| screen_pos.y > uResolution.y - 1
    ) return 0;

    // FIX 1: real 3D distance to observer (in parsecs, matching global_pos units)
    float observer_distance = length(global_pos - uObserverPosWorld);
    // FIX 2: feed getSolidAngleOfPixel NDC coords in [-1, 1], not [0, 1]
    vec2 ndc_xy = (pixel_and_depth.xy / vec2(uResolution)) * 2.0 - 1.0;
    vec3 screenSpacePos = vec3(ndc_xy, pixel_and_depth.z);

    float solidAngle = getSolidAngleOfPixel(vec4(screenSpacePos, 1.0), uResolution, uInvP);
    float apparentMagnitude = getApparentMagnitude(absMag, observer_distance);

    float lumi = magnitudeToLuminance(apparentMagnitude, solidAngle);

    ivec2 pixel = screen_pos;

    ////////////////////////////////////////////
    ivec2 outSize           = uResolution;
    vec2  starCoords        = (pixel_and_depth.xy) - 0.5;
    ivec2 integerStarCoords = ivec2(floor(starCoords));

#ifdef ENABLE_LUMI_THRESHOLD
    if(lumi < 0.0000000002) { //use rand to drop 99% for mem write distinction
        ivec2 tile_local_pos = integerStarCoords - ivec2(tileBasePx);
        writePixel(tile_local_pos, integerStarCoords, temp, lumi);
        return 1;
    }
#endif

    // Compute the fractional part of the star coordinates.
    vec2 starWeights = fract(starCoords);

    ivec2 targetStarCoords[4] = {
    integerStarCoords,
    integerStarCoords + ivec2(1, 0),
    integerStarCoords + ivec2(0, 1),
    integerStarCoords + ivec2(1, 1)
    };


    // Linear interpolation weights for the four nearest pixels.
    float weights[4] = {(1 - starWeights.x) * (1 - starWeights.y),
        starWeights.x * (1 - starWeights.y), (1 - starWeights.x) * starWeights.y,
        starWeights.x * starWeights.y};
    ////////////////////////////////////////////
    
    for(uint px = 0; px < 4; px++) {
        ivec2 tile_local_pos = targetStarCoords[px] - ivec2(tileBasePx);
        writePixel(tile_local_pos, targetStarCoords[px], temp, lumi * weights[px]);
    }

    return 1;
}

uint draw(uint jobID, uvec2 tileBasePx) {
    uint columnID   = gl_LocalInvocationID.x;
    uint chunkCount = min(joblist[jobID].count, uint(MAX_JOB_CHUNKS));
    uint chunksTouched = 0u;

    for (uint i = 0u; i < chunkCount; ++i) {
        ChunkMeta meta = joblist[jobID].list[i];
        vec3 chunkGlobalPos = vec3(unpack_uvec4(meta.chunkID).yzw) - vec3(127);
        float chunkScale = float(uint(meta.chunkID >> 24) & 0x7F);
        bool renderInHighPrecision = ((meta.chunkID >> 31) == 1u);
        bool touched = false;

        for (uint localRow = 0u; localRow < meta.batchCount; ++localRow) {
            uint absRow      = meta.startBatch + localRow;
            uint rowStartPtr = absRow * THREAD_COUNT * 2u;
            uint highPrecisionRowStartPtr = absRow * THREAD_COUNT;

            uint posEncoded     = batchesFlat[rowStartPtr + columnID * 2u + 0u];
            uint magTempEncoded = batchesFlat[rowStartPtr + columnID * 2u + 1u];
            uint posEncodedHighPrecision = 0;

            if(renderInHighPrecision) {
                //just for testing, put back to writing the highp
                posEncodedHighPrecision = highPrecisionBatchesFlat[highPrecisionRowStartPtr + columnID];
                
            }

            float mag  = decodeMag(magTempEncoded);
            float temp = decodeTemp(magTempEncoded);
#ifdef WRITE_PROFILING_COUNTERS
            starsTotal[gl_LocalInvocationID.x] += 1u;
#endif
            if (posEncoded == 0xFFFFFFFFu) continue; // padding star //REVEAL(waste of memory fetches if preprocessing doesnt redistribute padding stars into less dense chunks, see c++ preprocessing::run side too)

            uint wasStarAdded = drawStar(posEncoded, posEncodedHighPrecision, chunkGlobalPos, tileBasePx, mag, temp, chunkScale);
#ifdef WRITE_PROFILING_COUNTERS
    starsDrawn[gl_LocalInvocationID.x] += wasStarAdded;
#endif
            touched = true;
        }
        if (touched) chunksTouched++;
    }
    return chunksTouched;
}

