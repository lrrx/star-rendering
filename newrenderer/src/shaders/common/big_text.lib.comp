void drawChar(uint ascii, ivec2 pos, vec4 color) {
    if (ascii < 32u || ascii > 126u) return;
    uint base = (ascii - 32u) * 2u;
    uint lo = FontGlyphs[base + 0u];
    uint hi = FontGlyphs[base + 1u];

    for (uint gy = 0u; gy < FONT_H; ++gy) {
        uint row = ((gy < 4u) ? (lo >> (gy * 8u))
                              : (hi >> ((gy - 4u) * 8u))) & 0xFFu;
        for (uint gx = 0u; gx < FONT_W; ++gx) {
            uint bit = (row >> gx) & 1u;
            ivec2 cell = pos + ivec2(int(gx), int(FONT_H - 1u - gy)) * SCALE;
            for (int sy = 0; sy < SCALE + 1; ++sy)
            for (int sx = 0; sx < SCALE + 1; ++sx) {
                ivec2 px = cell + ivec2(sx, sy);
                vec4 bg = vec4(vec3(0.035), 1.0);
                
                vec4 out_color = (bit == 1u) ? color : bg;
                imageStore(uFrameBuffer, px, out_color);
            }
        }
    }
}