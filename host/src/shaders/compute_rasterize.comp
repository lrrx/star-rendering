void DEBUG_fillPixelThick(ivec2 coord, vec4 color) {
    for(int x = 0; x < 3; x++) {
        for(int y = 0; y < 3; y++) {
            imageAtomicAdd(uColorBuffer, coord + ivec2(x,y),
