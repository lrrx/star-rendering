        ivec2 localPixel = ivec2(gl_LocalInvocationID.x / 2, ty);
        float val = localTile[localPixel.x][localPixel.y];
        ivec2 globalPixel = tileBasePixel + localPixel;
        if(val > 0.0) {
            imageAtomicAdd(uColorBuffer, tileBasePixel + localPixel, val);
        }
    }
    
#ifdef DEFINE_TEXT_ENABLED
    if(gl_GlobalInvocationID.x == 0) {
        drawInt(uFrameUS, ivec2(10, 10), false, vec4(1.0));
    }
#endif

#ifdef DEFINE_DEBUG_ENABLED
    vec4 clip = uViewProj * vec4(voxelCenter, 1.0);
    vec3 ndc = clip.xyz / clip.w;
    if (abs(ndc.x) > 1.0 || abs(ndc.y) > 1.0 || abs(ndc.z) > 1.0) return;
    ivec2 pixelVoxel;
    pixelVoxel.x = int((ndc.x * 0.5 + 0.5) * float(uResolution.x));
    pixelVoxel.y = int((ndc.y * 0.5 + 0.5) * float(uResolution.y));
    
    if(DEBUG_CELL_INFOS) DEBUG_drawDebugCellText(voxelCenter, ci, voxelColor);
    if(DEBUG_VOXEL_CENTERS) DEBUG_fillPixelThick(pixelVoxel, voxelColor);
    if(DEBUG_VOXEL_STAR_COUNTS) DEBUG_drawLine(pixelVoxel + ivec2(0, 5 + count), pixelVoxel + ivec2(0, 5), voxelColor);
    if(DEBUG_VOXEL_OUTLINES) DEBUG_drawVoxelOutline(voxelCenter, uCellSize, voxelColor);
    if(DEBUG_BINARY_STRIPES) DEBUG_drawBinaryStripes(ci);
    if(DEBUG_ISOMETRIC_MINIMAP) DEBUG_drawIsometricMinimap(voxelCenter, count);
#endif
}
