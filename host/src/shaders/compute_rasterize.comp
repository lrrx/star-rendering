vec3 unpackLocalPosition(uint packedPos) {
    // Mask and shift to get 10-bit values
    float x = float((packedPos >> 20) & 0x3FFu) / 1023.0;
    float y = float((packedPos >> 10) & 0x3FFu) / 1023.0;
    float z = float(packedPos & 0x3FFu) / 1023.0;

    // Map [0, 1] back to [-0.5, 0.5]
    return vec3(x, y, z) - 0.5;
}

