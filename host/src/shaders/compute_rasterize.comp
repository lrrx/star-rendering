ivec2 toScreen(vec3 pos) {
    ivec2 ret = ivec2(-1);

    // Clip Space
    vec4 clip = vec4(0.0);
    if(USE_FLAT_TOP_PROJECTION) {
        vec4 clip = vec4((pos - uCameraPos) / 4.0, 1.0).xzyw;
        clip.x /= 16.f / 9.f;
    }
    else {
        clip = uViewProj * vec4(pos, 1.0);
    }

    if (clip.w <= 0.0) return ret;

    // NDC
    vec3 ndc = clip.xyz / clip.w;
    if (abs(ndc.x) > 1.0 || abs(ndc.y) > 1.0 || abs(ndc.z) > 1.0)
        return ret;

    // Pixel-Koordinaten
    ivec2 pixel;
    pixel.x = int((ndc.x * 0.5 + 0.5) * float(uResolution.x));
    pixel.y = int((ndc.y * 0.5 + 0.5) * float(uResolution.y));

    if (pixel.x < 0 || pixel.x >= uResolution.x ||
        pixel.y < 0 || pixel.y >= uResolution.y)
        return ret;

    return pixel;
}

vec4 unpackVec4(uint v) {
    vec4 unpacked;
    unpacked.x = float((v & uint(0xff000000)) >> 24);
    unpacked.y = float((v & uint(0x00ff0000)) >> 16);
    unpacked.z = float((v & uint(0x0000ff00)) >> 8);
    unpacked.w = float((v & uint(0x000000ff)) >> 0);
    return unpacked;
}

vec3 decodeVoxelCenter(uint id) {
    vec3 voxelCenter = unpackVec4(id).yzw;
    voxelCenter -= vec3(128.0);

    return voxelCenter * uCellSize;
}

//matrix for isometric projection of 3D to 2D
const mat3 isoMat = mat3(
    sqrt(3),   -1, sqrt(2),
    0,          2, sqrt(2),
    -sqrt(3),  -1, sqrt(2)
);

vec4 getPseudorandomStarColor(uint global_idx, vec3 pos) {
    float temperature = rand(float(global_idx)) * 9700.0 + 2300.0;
    float M = 2.0 + (1.0 - temperature / 10000.0) * rand(float(global_idx)) * 1.0;

    
    float dist = length(pos - uCameraPos) / 50.f;
    //TODO: measure distance in parsecs, calculate distance accordingly
    //float dist_pc = dist;// / cParsecToMeter;

    float apparentMagnitude = M + 5.0 * log10(dist / 10.0) * 1.0;
    float brightness = pow(5.0, -0.4 * apparentMagnitude);   // ≈ 10^(–0.4 m)

    /* FROM COSMOSCOUT, use later
        vec4 vScreenSpacePos = uMatP * uMatMV * vec4(pos * cParsecToMeter, 1);
        float vMagnitude  = getApparentMagnitude(M, dist_pc);
        float solidAngle = getSolidAngleOfPixel(vScreenSpacePos, uResolution, uInvP);
        float luminance  = magnitudeToLuminance(vMagnitude, solidAngle);
    */

    return vec4(
        CS_getStarColor(temperature) * brightness * 0.01,
        1.0
    );
}

