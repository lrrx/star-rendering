// --- draw a single ASCII character using blit32 ---
void drawChar(uint ascii, ivec2 pos, vec4 color) {
    if (ascii < 32u || ascii > 126u) return;
    uint glyph = blit32_Glyphs[ascii - 32u];

    for (int gy = 0; gy < int(BLIT32_HEIGHT); gy++) {
        for (int gx = 0; gx < int(BLIT32_WIDTH); gx++) {
            uint shift = uint(gy) * BLIT32_WIDTH + uint(gx);
            uint bit   = (glyph >> shift) & 1u;
            if (bit != 0u) {
                imageAtomicAdd(uColorBuffer, pos + ivec2(gx, BLIT32_HEIGHT - gy), 1.0);
            }
        }
    }
}

// --- print int in decimal or hex, controlled by hexMode ---
void drawInt(int n, ivec2 pos, bool hexMode, vec4 color) {
    uint v = uint(abs(n));
    uint digits[16];
    int  count = 0;

    if (v == 0u) {
        drawChar(48u, pos, color); // '0'
        return;
    }

    if (!hexMode) {
        while (v > 0u && count < 10) {
            digits[count++] = 48u + (v % 10u); // '0' + digit
            v /= 10u;
        }
    } else {
        while (v > 0u && count < 8) {
            uint nib = v & 0xFu;
            digits[count++] = (nib < 10u)
                ? (48u + nib)      // '0'..'9'
                : (55u + nib);     // 'A'..'F' (55 = 'A' - 10)
            v >>= 4;
        }
    }

    if(n < 0 && !hexMode) drawChar(45, pos - ivec2(BLIT32_ADVANCE, 0), color); //minus sign if negative

    for (int i = count - 1; i >= 0; --i) {
        drawChar(digits[i], pos, color);
        pos.x += int(BLIT32_ADVANCE);
    }
}
